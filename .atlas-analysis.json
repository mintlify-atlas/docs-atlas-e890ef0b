  "keyFeatures": [
    "Persistent headless browser automation with Playwright",
    "Eight opinionated workflow skills as slash commands",
    "Diff-aware QA testing for feature branches",
    "Automated code review with Greptile integration",
    "One-command shipping workflow (sync, test, PR)",
    "CEO and engineering plan review modes",
    "Browser cookie import from Chrome/Arc/Brave/Edge",
    "Engineering retrospectives with team metrics"
  ],
  "publicApiSurface": [
    "/browse - Browser automation commands",
    "/qa - QA testing workflow",
    "/ship - Automated shipping workflow",
    "/review - Code review workflow",
    "/plan-ceo-review - Product review mode",
    "/plan-eng-review - Engineering review mode",
    "/retro - Retrospective analysis",
    "/setup-browser-cookies - Cookie import",
    "browse goto <url> - Navigate to URL",
    "browse snapshot -i - Get accessibility tree with refs",
    "browse click @ref - Click element by ref",
    "browse fill @ref <value> - Fill input field",
    "browse screenshot <path> - Take screenshot",
    "browse text - Get page text content",
    "browse console - Get console messages",
    "browse network - Get network requests"
  ]
